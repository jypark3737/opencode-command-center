COMMAND_CENTER_URL=wss://your-app.railway.app/ws
COMMAND_CENTER_API_KEY=your-secret-api-key-here
DEVICE_ID=device-unique-id-here
DEVICE_NAME=my-server-01
# JSON array of projects this daemon manages
PROJECTS=[{"path":"/home/user/project1","name":"Project 1"},{"path":"/home/user/project2","name":"Project 2"}]
# Optional: override opencode binary path
OPENCODE_BIN=opencode
# Optional: directory used as opencode state root. Defaults to ${XDG_DATA_HOME}/opencode.
# Keep this per-device to avoid sharing SQLite/session state across daemon containers.
OPENCODE_HOME=/home/user/.local/share/opencode
# Optional: full sqlite db path (defaults to ${OPENCODE_HOME}/${DEVICE_ID}/opencode.db)
OPENCODE_DB_PATH=/home/user/.local/share/opencode/my-device-id/opencode.db
XDG_DATA_HOME=/home/user/.local/share
XDG_CONFIG_HOME=/home/user/.config
XDG_STATE_HOME=/home/user/.local/state
XDG_CACHE_HOME=/home/user/.cache
