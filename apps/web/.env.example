# OpenCode Command Center — Web App Environment Variables

# PostgreSQL connection string
DATABASE_URL="postgresql://opencode:password@localhost:5432/opencode_cc"

# Secret API key — shared between web app and all agent daemons
# Generate with: openssl rand -hex 32
COMMAND_CENTER_API_KEY="your-secret-api-key-here"

# Anthropic API key — used for on-demand task review
ANTHROPIC_API_KEY="sk-ant-..."

# Port (default: 3000)
PORT=3000

# Exposed to browser for API calls (same as COMMAND_CENTER_API_KEY)
NEXT_PUBLIC_API_KEY="your-secret-api-key-here"
